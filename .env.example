# Telegram API credentials — get from https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_GROUP_ID=

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=helpertips
DB_USER=helpertips_user
DB_PASSWORD=

# Dashboard
# Set to true for local development hot-reload; false (default) in production
DASH_DEBUG=false
DASHBOARD_USER=
DASHBOARD_PASSWORD=

# AWS (Phase 6 — deixar vazio ate o deploy)
# AWS_REGION=
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Telegram Bot para alertas de falha do servico (opcional)
# Criar bot via @BotFather, obter token e chat_id
# TELEGRAM_NOTIFY_TOKEN=
# TELEGRAM_NOTIFY_CHAT_ID=
